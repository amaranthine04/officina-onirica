---
import BaseLayout from '../layouts/BaseLayout.astro';

const atelier = [
  {
    title: 'Atelier Creativi',
    excerpt: 'Laboratori e workshop per stimolare la creatività, aperti a tutti. Brevi, intensi, accessibili.',
    href: '/atelier-creativi',
    bg: 'bg-cipria/20',
    photoBg: 'bg-cipria/50',
    photoLabel: 'PLACEHOLDER FOTO CREATIVI',
  },
  {
    title: 'Atelier Terapeutici',
    excerpt: 'Percorsi individuali e di gruppo per affrontare, elaborare e riequilibrare. Duraturi quanto serve.',
    href: '/atelier-terapeutici',
    bg: 'bg-salvia-chiaro/50',
    photoBg: 'bg-salvia-chiaro',
    photoLabel: 'PLACEHOLDER FOTO TERAPEUTICI',
  },
  {
    title: 'Atelier Formativi',
    excerpt: 'Formazione professionale in arte terapia per operatori, terapisti e professionisti del settore.',
    href: '/atelier-formativi',
    bg: 'bg-azzurro',
    photoBg: 'bg-azzurro/60',
    photoLabel: 'PLACEHOLDER FOTO FORMATIVI',
  },
];
---

<BaseLayout
  title="Cosa facciamo — Officina Onirica"
  description="Officina Onirica propone atelier creativi, terapeutici e formativi. Arte terapia individuale e di gruppo a Cassano Magnago."
>

  <!-- ─── HERO ──────────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-salvia-chiaro/60">
      <div class="flex h-full w-full items-center justify-center">
        <p class="font-sans text-sm text-salvia/50">[PLACEHOLDER FOTO]</p>
      </div>
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-white/95 via-white/70 to-transparent"></div>
    <div class="relative mx-auto max-w-6xl px-6 pb-16 pt-20 md:pb-24 md:pt-28">
      <p class="mb-3 font-sans text-xs font-medium uppercase tracking-[0.25em] text-corallo">
        Cosa facciamo
      </p>
      <h1 class="font-display text-4xl font-semibold leading-tight text-bruno md:text-5xl lg:text-6xl">
        I nostri atelier
      </h1>
    </div>
  </section>

  <!-- ─── INTRO + CARD ──────────────────────────────────────────────────────── -->
  <section class="py-14 md:py-20">
    <div class="mx-auto max-w-6xl px-6">

      <p class="mb-14 text-center font-sans text-base leading-relaxed text-bruno/70 md:text-lg">
        Proponiamo <strong class="font-semibold text-bruno">atelier creativi, terapeutici e formativi</strong>,
        pensati per rispettare i tempi e la storia di ciascuno.
        Ogni percorso nasce dall'incontro tra chi siamo e chi ci viene a trovare.
      </p>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {atelier.map(a => (
          <a href={a.href} class={`flex flex-col ${a.bg} transition-opacity duration-200 hover:opacity-90`}>
            <div class={`aspect-[4/3] w-full ${a.photoBg}`}>
              <div class="flex h-full w-full items-center justify-center">
                <p class="font-sans text-xs text-bruno/30">[{a.photoLabel}]</p>
              </div>
            </div>
            <div class="flex flex-1 flex-col p-8">
              <h2 class="font-display mb-3 text-3xl font-semibold text-bruno">{a.title}</h2>
              <p class="mb-8 flex-1 font-sans text-sm leading-relaxed text-bruno/65">{a.excerpt}</p>
              <span class="inline-block self-start border-b border-corallo pb-0.5 font-sans text-sm font-semibold text-corallo">
                Scopri di più →
              </span>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

</BaseLayout>
