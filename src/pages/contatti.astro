---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contatti — Officina Onirica"
  description="Contatta Officina Onirica per informazioni su percorsi, gruppi o per prenotare un primo incontro. Siamo a Cassano Magnago (VA)."
>

  <!-- ─── HERO ──────────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-salvia-chiaro/60">
      <div class="flex h-full w-full items-center justify-center">
        <p class="font-sans text-sm text-salvia/50">[PLACEHOLDER FOTO]</p>
      </div>
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-white/95 via-white/70 to-transparent"></div>
    <div class="relative mx-auto max-w-6xl px-6 pb-16 pt-20 md:pb-24 md:pt-28">
      <p class="mb-3 font-sans text-xs font-medium uppercase tracking-[0.25em] text-corallo">
        Contatti
      </p>
      <h1 class="font-display text-4xl font-semibold leading-tight text-bruno md:text-5xl lg:text-6xl">
        Scrivici
      </h1>
    </div>
  </section>

  <!-- ─── INTRO ─────────────────────────────────────────────────────────────── -->
  <section class="bg-cipria/20 py-12 md:py-16">
    <div class="mx-auto max-w-6xl px-6">
      <p class="text-center font-sans text-base leading-relaxed text-bruno/70 md:text-lg">
        Per informazioni su <strong class="font-semibold text-bruno">percorsi, gruppi</strong> o per prenotare un primo incontro,
        scrivici o vieni a trovarci in atelier.
      </p>
    </div>
  </section>

  <!-- ─── MAPPA + FORM ──────────────────────────────────────────────────────── -->
  <section class="py-14 md:py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid grid-cols-1 gap-12 md:grid-cols-2 md:gap-16">

        <!-- Colonna sinistra: recapiti + mappa -->
        <div class="order-2 flex flex-col gap-8 md:order-1">

          <!-- Recapiti -->
          <div>
            <p class="mb-2 font-sans text-xs font-medium uppercase tracking-[0.25em] text-corallo">
              Dove siamo
            </p>
            <h2 class="font-display mb-6 text-3xl font-semibold text-bruno md:text-4xl">
              Trovaci
            </h2>
            <ul class="space-y-4 font-sans text-sm leading-relaxed text-bruno/70">
              <li class="flex gap-3">
                <span class="mt-0.5 shrink-0 text-corallo">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
                  </svg>
                </span>
                <span>Via IV Novembre 24<br />Cassano Magnago (VA)</span>
              </li>
              <li class="flex gap-3">
                <span class="mt-0.5 shrink-0 text-corallo">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.99 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.92 1.17h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 5.99 5.99l1.19-1.19a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.02z"/>
                  </svg>
                </span>
                <a href="tel:+393471846458" class="transition-colors duration-200 hover:text-corallo">347 1846458</a>
              </li>
              <li class="flex gap-3">
                <span class="mt-0.5 shrink-0 text-corallo">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
                  </svg>
                </span>
                <span class="flex flex-col gap-1">
                  <a href="mailto:laurasaporiti72@gmail.com" class="transition-colors duration-200 hover:text-corallo">laurasaporiti72@gmail.com</a>
                  <a href="mailto:albertoponti05@gmail.com" class="transition-colors duration-200 hover:text-corallo">albertoponti05@gmail.com</a>
                </span>
              </li>
              <li class="flex gap-3">
                <span class="mt-0.5 shrink-0 text-corallo">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                  </svg>
                </span>
                <span>Su appuntamento</span>
              </li>
            </ul>
          </div>

          <!-- Mappa Google Maps -->
          <div class="overflow-hidden">
            <iframe
              src="https://maps.google.com/maps?q=Via+IV+Novembre+24,+Cassano+Magnago+VA,+Italy&output=embed&z=15"
              width="100%"
              height="320"
              style="border:0;"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Officina Onirica — Via IV Novembre 24, Cassano Magnago"
              class="w-full"
            ></iframe>
          </div>

        </div>

        <!-- Colonna destra: form -->
        <div class="order-1 md:order-2">
          <p class="mb-2 font-sans text-xs font-medium uppercase tracking-[0.25em] text-corallo">
            Modulo
          </p>
          <h2 class="font-display mb-6 text-3xl font-semibold text-bruno md:text-4xl">
            Scrivici
          </h2>

          <form
            id="contact-form"
            name="contatto-generico"
            method="POST"
            action="/contatti/grazie"
            data-netlify="true"
            class="space-y-5"
          >
            <input type="hidden" name="form-name" value="contatto-generico" />

            <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
              <div>
                <label class="mb-1.5 block font-sans text-xs font-medium uppercase tracking-[0.15em] text-bruno/60">
                  Nome *
                </label>
                <input
                  type="text"
                  name="nome"
                  required
                  class="w-full border border-bruno/20 bg-white px-4 py-3 font-sans text-sm text-bruno placeholder:text-bruno/30 focus:border-corallo focus:outline-none"
                  placeholder="Il tuo nome"
                />
              </div>
              <div>
                <label class="mb-1.5 block font-sans text-xs font-medium uppercase tracking-[0.15em] text-bruno/60">
                  Email *
                </label>
                <input
                  type="email"
                  name="email"
                  required
                  class="w-full border border-bruno/20 bg-white px-4 py-3 font-sans text-sm text-bruno placeholder:text-bruno/30 focus:border-corallo focus:outline-none"
                  placeholder="nome@email.it"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
              <div>
                <label class="mb-1.5 block font-sans text-xs font-medium uppercase tracking-[0.15em] text-bruno/60">
                  Telefono
                </label>
                <input
                  type="tel"
                  name="telefono"
                  class="w-full border border-bruno/20 bg-white px-4 py-3 font-sans text-sm text-bruno placeholder:text-bruno/30 focus:border-corallo focus:outline-none"
                  placeholder="+39 000 000 0000"
                />
              </div>
              <div>
                <label class="mb-1.5 block font-sans text-xs font-medium uppercase tracking-[0.15em] text-bruno/60">
                  Mi interessa
                </label>
                <select
                  name="interesse"
                  class="w-full border border-bruno/20 bg-white px-4 py-3 font-sans text-sm text-bruno focus:border-corallo focus:outline-none"
                >
                  <option value="">— Seleziona —</option>
                  <option value="Atelier Creativi">Atelier Creativi</option>
                  <option value="Atelier Terapeutici">Atelier Terapeutici</option>
                  <option value="Atelier Formativi">Atelier Formativi</option>
                  <option value="Informazioni generali">Informazioni generali</option>
                  <option value="Altro">Altro</option>
                </select>
              </div>
            </div>

            <div>
              <label class="mb-1.5 block font-sans text-xs font-medium uppercase tracking-[0.15em] text-bruno/60">
                Messaggio *
              </label>
              <textarea
                name="messaggio"
                rows="5"
                required
                class="w-full border border-bruno/20 bg-white px-4 py-3 font-sans text-sm text-bruno placeholder:text-bruno/30 focus:border-corallo focus:outline-none"
                placeholder="Raccontaci brevemente la tua situazione o la tua richiesta…"
              ></textarea>
            </div>

            <div class="flex items-start gap-3">
              <input
                type="checkbox"
                name="privacy"
                id="privacy-contatti"
                required
                class="mt-1 h-4 w-4 shrink-0 cursor-pointer border border-bruno/30 accent-corallo"
              />
              <label for="privacy-contatti" class="font-sans text-xs leading-relaxed text-bruno/55">
                Ho letto e accetto il trattamento dei miei dati personali ai sensi del Regolamento UE 2016/679 (<a href="/privacy-policy" class="text-corallo underline-offset-2 hover:underline">GDPR</a>). *
              </label>
            </div>

            <p class="font-sans text-xs text-bruno/40">* campi obbligatori.</p>

            <button
              type="submit"
              class="inline-block bg-corallo px-8 py-3 font-sans text-sm font-semibold tracking-wide text-white transition-opacity duration-200 hover:opacity-85"
            >
              Invia richiesta
            </button>
          </form>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>
