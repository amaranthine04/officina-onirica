---
import BaseLayout from '../layouts/BaseLayout.astro';

const atelier = [
  {
    title: 'Atelier Creativi',
    excerpt: 'Laboratori e workshop per stimolare la creatività, aperti a tutti. Brevi, intensi, accessibili.',
    href: '/atelier-creativi',
    bg: 'bg-cipria/20',
    photo: 'hero-creativi',
    alt: 'Atelier Creativi — Officina Onirica',
  },
  {
    title: 'Atelier Terapeutici',
    excerpt: 'Percorsi individuali e di gruppo per affrontare, elaborare e riequilibrare. Duraturi quanto serve.',
    href: '/atelier-terapeutici',
    bg: 'bg-salvia-chiaro/50',
    photo: 'hero-percorsiterapeutici',
    alt: 'Atelier Terapeutici — Officina Onirica',
  },
  {
    title: 'Atelier Formativi',
    excerpt: 'Formazione professionale in arte terapia per operatori, terapisti e professionisti del settore.',
    href: '/atelier-formativi',
    bg: 'bg-azzurro',
    photo: 'hero-formativi',
    alt: 'Atelier Formativi — Officina Onirica',
  },
];
---

<BaseLayout
  title="Cosa facciamo — Officina Onirica"
  description="Officina Onirica propone Atelier Creativi, Terapeutici e Formativi. Arte terapia per ogni età e ogni esigenza, a Cassano Magnago."
>

  <!-- ─── HERO ──────────────────────────────────────────────────────────────── -->
  <section class="relative flex min-h-[360px] flex-col justify-end overflow-hidden md:min-h-[420px]">
    <picture>
      <source srcset="/images/hero-ateliernostri.webp" type="image/webp" />
      <img src="/images/hero-ateliernostri.jpg" alt="I nostri atelier — Officina Onirica" class="absolute inset-0 h-full w-full object-cover" fetchpriority="high" decoding="async" />
    </picture>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at bottom left, rgba(255,255,255,0.98) 0%, rgba(255,255,255,0.78) 45%, rgba(255,255,255,0.28) 65%, transparent 80%)"></div>
    <div class="relative mx-auto w-full max-w-6xl px-6 pb-12 md:pb-16">
      <p class="mb-3 font-sans text-xs font-medium uppercase tracking-[0.25em] text-corallo">
        Cosa facciamo
      </p>
      <h1 class="font-display text-4xl font-semibold leading-tight text-bruno md:text-5xl lg:text-6xl">
        I nostri atelier
      </h1>
    </div>
  </section>

  <!-- ─── INTRO + CARD ──────────────────────────────────────────────────────── -->
  <section class="py-14 md:py-20">
    <div class="mx-auto max-w-6xl px-6">

      <p class="mb-14 text-center font-sans text-base leading-relaxed text-bruno/70 md:text-lg">
        Proponiamo <strong class="font-semibold text-bruno">atelier creativi, terapeutici e formativi</strong>,
        pensati per rispettare i tempi e la storia di ciascuno.
        Ogni percorso nasce dall'incontro tra chi siamo e chi ci viene a trovare.
      </p>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {atelier.map(a => (
          <a href={a.href} class={`flex flex-col ${a.bg} transition-opacity duration-200 hover:opacity-90`}>
            <div class="relative aspect-[4/3] w-full overflow-hidden">
              <picture class="block h-full w-full">
                <source srcset={`/images/${a.photo}.webp`} type="image/webp" />
                <img src={`/images/${a.photo}.jpg`} alt={a.alt} class="h-full w-full object-cover" loading="lazy" decoding="async" />
              </picture>
            </div>
            <div class="flex flex-1 flex-col p-8">
              <h2 class="font-display mb-3 text-3xl font-semibold text-bruno">{a.title}</h2>
              <p class="mb-8 flex-1 font-sans text-sm leading-relaxed text-bruno/65">{a.excerpt}</p>
              <span class="inline-block self-start border-b border-corallo pb-0.5 font-sans text-sm font-semibold text-corallo">
                Scopri di più →
              </span>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

</BaseLayout>
