---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

function formatDate(date: Date) {
  return date.toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<BaseLayout
  title="Bacheca — Officina Onirica"
  description="Aggiornamenti, approfondimenti ed eventi da Officina Onirica."
>

  <!-- ─── HERO ──────────────────────────────────────────────────────────────── -->
  <section class="relative flex min-h-[360px] flex-col justify-end overflow-hidden md:min-h-[420px]">
    <picture>
      <source srcset="/images/hero-bacheca.webp" type="image/webp" />
      <img src="/images/hero-bacheca.jpg" alt="Bacheca — Officina Onirica" class="absolute inset-0 h-full w-full object-cover" fetchpriority="high" decoding="async" />
    </picture>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at bottom left, rgba(255,255,255,0.98) 0%, rgba(255,255,255,0.78) 45%, rgba(255,255,255,0.28) 65%, transparent 80%)"></div>
    <div class="relative mx-auto w-full max-w-6xl px-6 pb-12 md:pb-16">
      <p class="mb-3 font-sans text-xs font-medium uppercase tracking-[0.25em] text-corallo">
        Novità
      </p>
      <h1 class="font-display text-4xl font-semibold leading-tight text-bruno md:text-5xl lg:text-6xl">
        Bacheca
      </h1>
    </div>
  </section>

  <!-- ─── LISTA ARTICOLI ────────────────────────────────────────────────────── -->
  <section class="py-14 md:py-20">
    <div class="mx-auto max-w-4xl px-6">

      {posts.length === 0 ? (
        <p class="font-sans text-sm text-bruno/50">Nessun articolo ancora pubblicato.</p>
      ) : (
        <ul class="divide-y divide-bruno/10">
          {posts.map(post => (
            <li class="py-10 first:pt-0 last:pb-0">
              <time class="mb-2 block font-sans text-xs font-medium uppercase tracking-[0.2em] text-corallo">
                {formatDate(post.data.date)}
              </time>
              <h2 class="font-display mb-3 text-3xl font-semibold leading-tight text-bruno md:text-4xl">
                <a
                  href={`/bacheca/${post.id}`}
                  class="transition-colors duration-200 hover:text-corallo"
                >
                  {post.data.title}
                </a>
              </h2>
              <p class="mb-5 font-sans text-sm leading-relaxed text-bruno/65">
                {post.data.description}
              </p>
              <a
                href={`/bacheca/${post.id}`}
                class="inline-block border-b border-corallo pb-0.5 font-sans text-sm font-semibold text-corallo transition-all duration-200 hover:pb-1"
              >
                Leggi di più →
              </a>
            </li>
          ))}
        </ul>
      )}

    </div>
  </section>

</BaseLayout>
