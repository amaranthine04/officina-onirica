---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

function formatDate(date: Date) {
  return date.toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<BaseLayout
  title="Bacheca — Officina Onirica"
  description="Aggiornamenti, approfondimenti ed eventi da Officina Onirica."
>

  <!-- ─── HERO ──────────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-cipria/40">
      <div class="flex h-full w-full items-center justify-center">
        <p class="font-sans text-sm text-bruno/25">[PLACEHOLDER FOTO]</p>
      </div>
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-white/95 via-white/70 to-transparent"></div>
    <div class="relative mx-auto max-w-6xl px-6 pb-16 pt-20 md:pb-24 md:pt-28">
      <p class="mb-3 font-sans text-xs font-medium uppercase tracking-[0.25em] text-corallo">
        Novità
      </p>
      <h1 class="font-display text-4xl font-semibold leading-tight text-bruno md:text-5xl lg:text-6xl">
        Bacheca
      </h1>
    </div>
  </section>

  <!-- ─── INTRO ─────────────────────────────────────────────────────────────── -->
  <section class="bg-azzurro py-14 md:py-20">
    <div class="mx-auto max-w-6xl px-6 text-center">
      <p class="font-sans text-base leading-relaxed text-bruno/70">
        Aggiornamenti, approfondimenti ed eventi da Officina Onirica.
      </p>
    </div>
  </section>

  <!-- ─── LISTA ARTICOLI ────────────────────────────────────────────────────── -->
  <section class="py-14 md:py-20">
    <div class="mx-auto max-w-4xl px-6">

      {posts.length === 0 ? (
        <p class="font-sans text-sm text-bruno/50">Nessun articolo ancora pubblicato.</p>
      ) : (
        <ul class="divide-y divide-bruno/10">
          {posts.map(post => (
            <li class="py-10 first:pt-0 last:pb-0">
              <time class="mb-2 block font-sans text-xs font-medium uppercase tracking-[0.2em] text-corallo">
                {formatDate(post.data.date)}
              </time>
              <h2 class="font-display mb-3 text-3xl font-semibold leading-tight text-bruno md:text-4xl">
                <a
                  href={`/bacheca/${post.id}`}
                  class="transition-colors duration-200 hover:text-corallo"
                >
                  {post.data.title}
                </a>
              </h2>
              <p class="mb-5 font-sans text-sm leading-relaxed text-bruno/65">
                {post.data.description}
              </p>
              <a
                href={`/bacheca/${post.id}`}
                class="inline-block border-b border-corallo pb-0.5 font-sans text-sm font-semibold text-corallo transition-all duration-200 hover:pb-1"
              >
                Leggi di più →
              </a>
            </li>
          ))}
        </ul>
      )}

    </div>
  </section>

</BaseLayout>
