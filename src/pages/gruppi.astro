---
import BaseLayout from '../layouts/BaseLayout.astro';

const gruppi = [
  {
    title: 'Gruppo Illustratori',
    excerpt: 'Info in aggiornamento.',
    href: '/gruppi/illustratori',
    bg: 'bg-salvia-chiaro/40',
    photoBg: 'bg-salvia-chiaro',
  },
  {
    title: 'Gruppo Espressivo',
    excerpt: 'Info in aggiornamento.',
    href: '/gruppi/espressivo',
    bg: 'bg-cipria/20',
    photoBg: 'bg-cipria/50',
  },
  {
    title: 'Gruppo Collage',
    excerpt: 'Info in aggiornamento.',
    href: '/gruppi/collage',
    bg: 'bg-salvia-chiaro/40',
    photoBg: 'bg-salvia-chiaro',
  },
];
---

<BaseLayout
  title="Gruppi di Arte Terapia — Officina Onirica"
  description="Gruppi di arte terapia in collaborazione con le associazioni del territorio. Officina Onirica, Cassano Magnago."
>

  <!-- ─── HERO ──────────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-salvia-chiaro/60">
      <div class="flex h-full w-full items-center justify-center">
        <p class="font-sans text-sm text-salvia/50">[PLACEHOLDER FOTO]</p>
      </div>
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-white/95 via-white/70 to-transparent"></div>
    <div class="relative mx-auto max-w-6xl px-6 pb-16 pt-20 md:pb-24 md:pt-28">
      <p class="mb-3 font-sans text-xs font-medium uppercase tracking-[0.25em] text-corallo">
        Cosa facciamo
      </p>
      <h1 class="font-display text-4xl font-semibold leading-tight text-bruno md:text-5xl lg:text-6xl">
        Gruppi di Arte Terapia
      </h1>
    </div>
  </section>

  <!-- ─── LISTA ─────────────────────────────────────────────────────────────── -->
  <section class="py-14 md:py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-14 space-y-4 text-center">
        <p class="font-sans text-base leading-relaxed text-bruno/70 md:text-lg">
          Gruppi di Arte Terapia in collaborazione con le associazioni del territorio, per ragazzi con sindrome di Down e persone con Parkinson.
        </p>
        <p class="font-sans text-base italic leading-relaxed text-bruno/50 md:text-lg">
          [Testo introduttivo da aggiungere — descrizione breve dei gruppi in generale]
        </p>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {gruppi.map(g => (
          <div class={`flex flex-col ${g.bg}`}>
            <a href={g.href} class={`block aspect-[4/3] w-full overflow-hidden ${g.photoBg} transition-opacity duration-200 hover:opacity-85`}>
              <div class="flex h-full w-full items-center justify-center">
                <p class="font-sans text-xs text-salvia/50">[foto {g.title.toLowerCase()}]</p>
              </div>
            </a>
            <div class="flex flex-1 flex-col p-6">
              <h2 class="font-display mb-3 text-3xl font-semibold text-bruno">{g.title}</h2>
              <p class="mb-6 flex-1 font-sans text-sm leading-relaxed text-bruno/65">{g.excerpt}</p>
              <a href={g.href} class="inline-block self-start border-b border-corallo pb-0.5 font-sans text-sm font-semibold text-corallo transition-all duration-200 hover:pb-1">
                Scopri di più →
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
