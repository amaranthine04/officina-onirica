---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title="Atelier Creativi — Officina Onirica"
  description="Laboratori e workshop creativi aperti a tutti a Cassano Magnago. Brevi percorsi per avvicinarsi all'arte espressiva con Officina Onirica."
>

  <!-- ─── HERO ──────────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-cipria/50">
      <div class="flex h-full w-full items-center justify-center">
        <p class="font-sans text-sm text-bruno/30">[PLACEHOLDER FOTO CREATIVI]</p>
      </div>
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-white/95 via-white/70 to-transparent"></div>
    <div class="relative mx-auto max-w-6xl px-6 pb-16 pt-20 md:pb-24 md:pt-28">
      <p class="mb-3 font-sans text-xs font-medium uppercase tracking-[0.25em] text-corallo">
        Atelier Creativi
      </p>
      <h1 class="font-display text-4xl font-semibold leading-tight text-bruno md:text-5xl lg:text-6xl">
        Dare forma alla creatività
      </h1>
    </div>
  </section>

  <!-- ─── INTRO ─────────────────────────────────────────────────────────────── -->
  <section class="py-14 md:py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid grid-cols-1 gap-12 md:grid-cols-2 md:gap-20">
        <div>
          <p class="mb-2 font-sans text-xs font-medium uppercase tracking-[0.25em] text-corallo">Cosa sono</p>
          <h2 class="font-display mb-6 text-3xl font-semibold text-bruno md:text-4xl">
            Brevi, intensi, accessibili
          </h2>
          <div class="space-y-4 font-sans text-sm leading-relaxed text-bruno/70">
            <p>
              I nostri Atelier Creativi sono laboratori ed esperienze brevi — spesso della durata di
              un weekend — pensati per stimolare il processo creativo attraverso le arti visive.
              <strong class="font-semibold text-bruno">Aperti a tutti</strong>, indipendentemente dall'età o dall'esperienza artistica.
            </p>
          </div>
        </div>

        <!-- Foto: mobile dopo il testo, desktop a destra -->
        <div class="aspect-[4/3] w-full bg-cipria/50">
          <div class="flex h-full w-full items-center justify-center">
            <p class="font-sans text-xs text-bruno/30">[PLACEHOLDER FOTO]</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── COME FUNZIONA ─────────────────────────────────────────────────────── -->
  <section class="bg-cipria/20 py-14 md:py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid grid-cols-1 gap-12 md:grid-cols-2 md:gap-20">
        <div>
          <p class="mb-2 font-sans text-xs font-medium uppercase tracking-[0.25em] text-corallo">Il formato</p>
          <h2 class="font-display mb-6 text-3xl font-semibold text-bruno md:text-4xl">
            Come funziona
          </h2>
          <div class="space-y-4 font-sans text-sm leading-relaxed text-bruno/70">
            <p>
              Gli Atelier Creativi si svolgono prevalentemente in gruppo, in un clima di condivisione
              e scoperta. Ogni incontro è un'esperienza a sé: breve, intensa, accessibile.
              <strong class="font-semibold text-bruno">Non serve saper disegnare</strong> — serve solo la voglia di esprimersi.
            </p>
            <p>
              I temi e le tecniche variano di volta in volta: pittura, collage, tecniche miste,
              lavoro con i materiali. Per conoscere i prossimi appuntamenti, consulta la nostra
              bacheca o <a href="#contatti" class="border-b border-corallo pb-0.5 text-corallo transition-all duration-200 hover:pb-1">scrivici direttamente</a>.
            </p>
          </div>
        </div>

        <!-- Foto: mobile dopo il testo (order), desktop a destra -->
        <div class="order-last aspect-[4/3] w-full bg-cipria/40 md:order-last">
          <div class="flex h-full w-full items-center justify-center">
            <p class="font-sans text-xs text-bruno/25">[PLACEHOLDER FOTO LABORATORIO]</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── A CHI SI RIVOLGE ──────────────────────────────────────────────────── -->
  <section class="py-14 md:py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid grid-cols-1 gap-12 md:grid-cols-2 md:gap-20">

        <div class="aspect-[4/3] w-full bg-cipria/60 order-last md:order-first">
          <div class="flex h-full w-full items-center justify-center">
            <p class="font-sans text-xs text-bruno/25">[PLACEHOLDER FOTO PARTECIPANTI]</p>
          </div>
        </div>

        <div class="flex flex-col justify-center">
          <p class="mb-2 font-sans text-xs font-medium uppercase tracking-[0.25em] text-corallo">Partecipanti</p>
          <h2 class="font-display mb-6 text-3xl font-semibold text-bruno md:text-4xl">
            A chi si rivolge
          </h2>
          <div class="space-y-4 font-sans text-sm leading-relaxed text-bruno/70">
            <p>
              A chiunque voglia avvicinarsi all'arte come strumento espressivo.
              <strong class="font-semibold text-bruno">Bambini, adulti e anziani</strong> sono tutti benvenuti — non
              esistono requisiti di età o di esperienza.
            </p>
            <p>
              Gli Atelier Creativi sono pensati per essere accessibili e inclusivi, uno spazio aperto
              a tutti coloro che sentono il desiderio di esprimersi attraverso l'arte.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ─── DOVE ──────────────────────────────────────────────────────────────── -->
  <section class="bg-cipria/20 py-14 md:py-20">
    <div class="mx-auto max-w-6xl px-6 text-center">
      <p class="mb-2 font-sans text-xs font-medium uppercase tracking-[0.25em] text-corallo">Sede</p>
      <h2 class="font-display mb-6 text-3xl font-semibold text-bruno md:text-4xl">
        Dove si svolge
      </h2>
      <p class="text-center font-sans text-sm leading-relaxed text-bruno/70">
        Gli Atelier Creativi si svolgono presso Officina Onirica, <a href="https://maps.google.com/maps?q=Via+IV+Novembre+24,+Cassano+Magnago+VA,+Italy" target="_blank" rel="noopener noreferrer" class="border-b border-corallo pb-0.5 text-corallo transition-all duration-200 hover:pb-1">Via IV Novembre 24, Cassano Magnago (VA)</a>. Per informazioni sui prossimi appuntamenti e le modalità
        di partecipazione, scrivici o chiamaci.
      </p>
    </div>
  </section>

  <!-- ─── FORM ──────────────────────────────────────────────────────────────── -->
  <section id="contatti" class="py-14 md:py-20">
    <div class="mx-auto max-w-3xl px-6">
      <p class="mb-2 font-sans text-xs font-medium uppercase tracking-[0.25em] text-corallo">Contatti</p>
      <h2 class="font-display mb-3 text-3xl font-semibold text-bruno md:text-4xl">
        Chiedi informazioni
      </h2>
      <p class="mb-10 font-sans text-sm leading-relaxed text-bruno/65">
        Vuoi partecipare a un Atelier Creativo o ricevere informazioni sui prossimi appuntamenti? Scrivici.
      </p>
      <ContactForm subject="Atelier Creativi" />
    </div>
  </section>

</BaseLayout>
